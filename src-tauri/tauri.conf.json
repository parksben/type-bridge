{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TypeBridge",
  "version": "0.1.0",
  "identifier": "com.typebridge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.typebridge/**"]
      }
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray-icon.png"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "externalBin": [
      "binaries/feishu-bridge",
      "binaries/dingtalk-bridge"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
