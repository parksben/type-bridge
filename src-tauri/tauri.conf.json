{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TypeBridge",
  "version": "0.1.0",
  "identifier": "com.typebridge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "(cd webchat-local && npm install --silent && npm run build) && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.typebridge/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "externalBin": [
      "binaries/feishu-bridge",
      "binaries/dingtalk-bridge",
      "binaries/wecom-bridge"
    ],
    "resources": {
      "../webchat-local/dist": "webchat-local/dist"
    },
    "macOS": {
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "height": 480,
          "width": 760
        },
        "appPosition": {
          "x": 206,
          "y": 278
        },
        "applicationFolderPosition": {
          "x": 554,
          "y": 278
        }
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
