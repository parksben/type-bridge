{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "TypeBridge default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:allow-get",
    "store:allow-set",
